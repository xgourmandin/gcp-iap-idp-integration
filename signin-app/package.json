{
  "name": "iap-signin-app",
  "version": "1.0.0",
  "description": "Custom IAP + Identity Platform (GCIP) sign-in page — Cloud Run service",
  "private": true,
  "scripts": {
    "build:server": "tsc -p tsconfig.server.json",
    "build:client": "node build.mjs",
    "build": "npm run build:server && npm run build:client",
    "start": "node dist/server/server.js",
    "dev": "ts-node --project tsconfig.server.json src/server/server.ts"
  },
  "dependencies": {
    "express": "^4.18.2",
    "firebase": "^9.8.3",
    "gcip-iap": "^2.0.0",
    "promise-polyfill": "^8.3.0",
    "url-polyfill": "^1.1.14",
    "whatwg-fetch": "^3.6.20"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.5",
    "esbuild": "0.25.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=20"
  }
}
